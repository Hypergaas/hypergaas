{
  "name": "@hypergaas/core",
  "version": "0.1.0",
  "description": "An open-source agent SDK for B2B SaaS: a typed, multi-tenant action registry over your existing service layer.",
  "keywords": [
    "agents",
    "ai",
    "saas",
    "multi-tenant",
    "typescript",
    "sdk",
    "tool-calling",
    "llm"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "hypergaas-extract": "dist/codegen/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "pnpm run codegen && tsc -p tsconfig.json",
    "codegen": "tsc -p tsconfig.codegen.json && node .codegen-dist/codegen/cli.js --tsconfig tsconfig.codegen-extract.json --out hypergaas.actions.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .codegen-dist hypergaas.actions.json"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hypergaas/hypergaas.git",
    "directory": "packages/hypergaas"
  },
  "homepage": "https://github.com/Hypergaas/hypergaas#readme",
  "bugs": {
    "url": "https://github.com/Hypergaas/hypergaas/issues"
  },
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
